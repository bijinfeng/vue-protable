{
  "name": "@vue-protable/antdv",
  "version": "0.0.1",
  "type": "module",
  "description": "Ant Design Vue Adapter for Headless ProTable",
  "license": "MIT",
  "author": "bijinfeng",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bijinfeng/vue-protable.git",
    "directory": "packages/antdv"
  },
  "homepage": "https://github.com/bijinfeng/vue-protable#readme",
  "bugs": {
    "url": "https://github.com/bijinfeng/vue-protable/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "table",
    "protable",
    "ant-design-vue"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "pnpm -w --filter @vue-protable/core build",
    "build": "tsdown"
  },
  "dependencies": {
    "@vue-protable/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": "catalog:",
    "ant-design-vue": "catalog:"
  },
  "devDependencies": {
    "ant-design-vue": "catalog:",
    "vue": "catalog:",
    "unplugin-vue": "catalog:",
    "vue-tsc": "catalog:"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  }
}
